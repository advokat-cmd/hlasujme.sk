datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Building {
  id           String   @id @default(uuid())
  name         String
  short        String?
  address      String
  entrance     String
  unitsCount   Int      @default(0)
  manager      String
  contact      String
  contactEmail String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  units        Unit[]
  polls        Poll[]
}

enum UnitType {
  byt
  nebyt
}

enum CoMode {
  single
  rep
  internal
  majority
  bsm
  legal
}

model Unit {
  id           String   @id @default(uuid())
  no           String
  type         UnitType
  floor        String
  votes        Int      @default(1)
  coMode       CoMode
  email        String?  // Main contact email for voting links
  actingPerson String?
  label        String?
  status       String   @default("active") // "active" | "inactive"

  buildingId   String
  building     Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  owners       Owner[]
  voteTokens   VoteToken[]
  castVotes    Vote[]
  castSubvotes CoownerSubvote[]
  admins       Admin[]

  @@unique([buildingId, no])
}

enum OwnerRole {
  owner
  coowner
  bsm
  proxy
  legal
}

model Owner {
  id         String    @id @default(uuid())
  first      String
  last       String
  name       String
  email      String?
  phone      String?
  birthDate  String?
  share      Float     @default(1.0)
  role       OwnerRole @default(owner)
  
  unitId     String
  unit       Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)

  subvotes   CoownerSubvote[]
  admins     Admin[]
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   // Argon2id hash
  name         String
  role         String   @default("admin") // "superadmin", "admin", "vlastnik"
  totpSecret   String?
  createdAt    DateTime @default(now())

  // Admin can be linked to an owner or unit
  unitId       String?
  unit         Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  ownerId      String?
  owner        Owner?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
}

model QuestionTemplate {
  id           String   @id @default(uuid())
  title        String
  text         String   @db.Text
  majorityType String
  note         String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailTemplate {
  key       String   @id
  subject   String
  body      String   @db.Text
  updatedAt DateTime @updatedAt
}

enum PollStatus {
  draft
  active
  closed
}

model Poll {
  id           String       @id @default(uuid())
  title        String
  reason       String
  declarer     String
  announcedAt  DateTime
  startAt      DateTime
  endAt        DateTime
  status       PollStatus   @default(draft)
  driveFolderId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  buildingId   String
  building     Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  questions         Question[]
  voteTokens        VoteToken[]
  votes             Vote[]
  subvotes          CoownerSubvote[]
  sealedResult      SealedResult?
  protocolEmailLogs ProtocolEmailLog[]
  documents         PollDocument[]
}

// Supporting document attached to a poll. Stored primarily on the server
// (storage/uploads), with Google Drive as a best-effort backup.
model PollDocument {
  id          String   @id @default(uuid())
  pollId      String
  poll        Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  questionNo  Int?     // optional link to a specific question
  name        String   // original file name shown to users
  mimeType    String
  size        Int      @default(0)
  localPath   String?  // relative path under storage/uploads
  driveFileId String?
  webViewLink String?
  createdAt   DateTime @default(now())

  @@index([pollId])
}

enum MajorityType {
  half_all       @map("half-all")
  twothirds_all  @map("twothirds-all")
  fourfifths_all @map("fourfifths-all")
  all
  half_present   @map("half-present")
}

model Question {
  id           String       @id @default(uuid())
  pollId       String
  poll         Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  no           Int
  kind         String
  title        String
  text         String
  majorityType MajorityType
  note         String?
  attachments  String[]     @default([])

  @@unique([pollId, no])
}

model VoteToken {
  id         String   @id @default(uuid())
  pollId     String
  poll       Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  
  // For internal voting where co-owners get individual tokens
  ownerId    String?
  
  tokenHash  String   @unique // CSPRNG token hash (SHA-256)
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([pollId, unitId])
}

enum VoteAnswer {
  agree
  disagree
  abstain
}

model Vote {
  id         String     @id @default(uuid())
  pollId     String
  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  questionNo Int
  answer     VoteAnswer
  version    Int        @default(1)
  createdAt  DateTime   @default(now())
  sourceIp   String?
  tokenId    String?

  @@unique([pollId, unitId, questionNo, version])
}

model CoownerSubvote {
  id         String     @id @default(uuid())
  pollId     String
  poll       Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  ownerId    String
  owner      Owner      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questionNo Int
  answer     VoteAnswer
  version    Int        @default(1)
  createdAt  DateTime   @default(now())
  sourceIp   String?
  tokenId    String?

  @@unique([pollId, unitId, ownerId, questionNo, version])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actor     String
  payload   String   // JSON string
  prevHash  String
  entryHash String   @unique
  createdAt DateTime @default(now())

  @@index([action, createdAt])
}

model SealedResult {
  id         String   @id @default(uuid())
  pollId     String   @unique
  poll       Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  
  resultJson String   // Serialized result details (tallies, votes etc.)
  sha256     String   // Hash of results data
  sealedAt   DateTime @default(now())
  pdfPath    String   // Path to PDF file on server

  // Google Drive backup tracking
  driveFileId      String?
  driveWebViewLink String?
  driveUploadedAt  DateTime?
}

model ProtocolEmailLog {
  id        String   @id @default(uuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  email     String
  sentAt    DateTime @default(now())

  @@index([pollId, email])
}
